# Copy to .env and fill in. Never commit .env.
# Generate secrets with:  openssl rand -hex 32

# --- Domain / TLS ---
DOMAIN=example.com                 # app at jarvis.<DOMAIN>, traces at traces.<DOMAIN>
ACME_EMAIL=you@example.com         # Let's Encrypt notifications

# --- App ---
JARVIS_ENV=prod
JARVIS_SECRET_KEY=                 # openssl rand -hex 32  (JWT signing)
TZ=Europe/Athens

# --- Postgres (shared by app + Langfuse) ---
POSTGRES_PASSWORD=                 # openssl rand -hex 32

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# VPS pointing at home-server Ollama over Tailscale:
#   OLLAMA_BASE_URL=http://100.x.y.z:11434
# Full stack running on the home server itself:
#   OLLAMA_BASE_URL=http://ollama:11434
# Leave empty to disable local models (API-only routing).
OLLAMA_BASE_URL=

# --- Langfuse (tracing) ---
LANGFUSE_SALT=                     # openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=           # openssl rand -hex 32  (must be 64 hex chars)
LANGFUSE_NEXTAUTH_SECRET=          # openssl rand -hex 32
LANGFUSE_ADMIN_EMAIL=you@example.com
LANGFUSE_ADMIN_PASSWORD=           # login for traces.<DOMAIN>; signup is disabled
# API keys the backend uses to send traces (bootstrapped on first start).
# Conventional formats: pk-lf-<random>, sk-lf-<random>
LANGFUSE_PUBLIC_KEY=pk-lf-
LANGFUSE_SECRET_KEY=sk-lf-

# --- Langfuse backing services ---
CLICKHOUSE_PASSWORD=               # openssl rand -hex 32
REDIS_PASSWORD=                    # openssl rand -hex 32
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=               # openssl rand -hex 32
